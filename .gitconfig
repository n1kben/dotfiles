[alias]
  stage = !git add
  unstage = !git reset
  staged = !git diff --cached
  undo = !git reset --mixed HEAD~1
  pop = !git stash pop
  amend = !git commit --amend --no-edit
  squash = !git rebase -i master
[include]
  path = ~/.gitconfig-override
[push]
  default = simple
[core]
  excludesfile = ~/.gitignore-global
  fileMode = false
  editor = nvim
  pager = hunk pager
[init]
  defaultBranch = main
[rerere]
  enabled = true
  autoUpdate = true
[branch]
  sort = -committerdate
[merge]
  conflictStyle = zdiff3
