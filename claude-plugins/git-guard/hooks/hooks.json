{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/block-no-verify-commit.sh\"",
            "statusMessage": "git-guard: checking commit"
          }
        ]
      }
    ]
  }
}
